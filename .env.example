# ==============================================
# R2 Data Node - Environment Variables Template
# ==============================================
# Rename this file to .env.local and fill values
# NEVER commit .env.local to GitHub!

# R2 Endpoint URL
# Format: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=your_r2_endpoint_here

# R2 API Keys (Create in Cloudflare Dashboard > R2 > API Tokens)
R2_ACCESS_KEY_ID=your_access_key_id_here
R2_SECRET_ACCESS_KEY=your_secret_access_key_here

# R2 Bucket Name
R2_BUCKET_NAME=your_bucket_name_here

# Optional: Public URL (for direct file previews)
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Optional: Legacy Admin Password (if not using Setup UI)
ADMIN_PASSWORD=your_password_here
